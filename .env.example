# Copiá este archivo a .env.local y completá con las claves de tu proyecto
# (Supabase → Settings → API Keys).

# URL del proyecto
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave publishable (sb_publishable_...): segura para el navegador,
# la protege RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Clave secret (sb_secret_...): SOLO servidor (invitaciones, admin).
# Nunca va con prefijo NEXT_PUBLIC_ ni se sube al repo.
SUPABASE_SECRET_KEY=sb_secret_...

# Ocultar el botón "Ingresar" de la landing (0 = oculto)
# NEXT_PUBLIC_MOSTRAR_INGRESO=0

# --- Convenio Colectivo con IA (Gemini) ---
# Habilitá la "Generative Language API" en Google Cloud / AI Studio y pegá la key.
# Solo servidor: NUNCA usar prefijo NEXT_PUBLIC_.
GEMINI_API_KEY=
# Modelo (opcional). Por defecto usa el más económico:
# GEMINI_MODEL=gemini-2.5-flash-lite
